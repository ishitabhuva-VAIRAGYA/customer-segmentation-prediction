# Import libraries
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

from sklearn.cluster import KMeans, AgglomerativeClustering, DBSCAN
from sklearn.preprocessing import StandardScaler
from sklearn.model_selection import train_test_split, GridSearchCV
from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score, roc_auc_score
from sklearn.decomposition import PCA

# Load dataset
df = pd.read_csv("customer_churn.csv")
print(df.head())

# -----------------------------
# STEP 1: Data Preprocessing
# -----------------------------
X = df.drop("Churn", axis=1)

scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

# -----------------------------
# STEP 2: K-Means Clustering
# -----------------------------
wcss = []
for i in range(1, 10):
    kmeans = KMeans(n_clusters=i, random_state=42)
    kmeans.fit(X_scaled)
    wcss.append(kmeans.inertia_)

plt.plot(range(1, 10), wcss, marker='o')
plt.title("Elbow Method")
plt.xlabel("Clusters")
plt.ylabel("WCSS")
plt.show()

# Final KMeans
kmeans = KMeans(n_clusters=3, random_state=42)
df["Cluster_KMeans"] = kmeans.fit_predict(X_scaled)

# -----------------------------
# STEP 3: Hierarchical Clustering
# -----------------------------
hc = AgglomerativeClustering(n_clusters=3)
df["Cluster_HC"] = hc.fit_predict(X_scaled)

# -----------------------------
# STEP 4: DBSCAN
# -----------------------------
dbscan = DBSCAN(eps=0.8, min_samples=5)
df["Cluster_DBSCAN"] = dbscan.fit_predict(X_scaled)

# -----------------------------
# STEP 5: Cluster Profiling
# -----------------------------
print(df.groupby("Cluster_KMeans").mean())

# -----------------------------
# STEP 6: Segment-wise Models
# -----------------------------
results = []

for segment in df["Cluster_KMeans"].unique():
    segment_df = df[df["Cluster_KMeans"] == segment]

    if len(segment_df) < 20:
        continue

    X_seg = segment_df.drop(["Churn", "Cluster_KMeans", "Cluster_HC", "Cluster_DBSCAN"], axis=1)
    y_seg = segment_df["Churn"]

    X_train, X_test, y_train, y_test = train_test_split(
        X_seg, y_seg, test_size=0.2, random_state=42
    )

    rf = RandomForestClassifier(random_state=42)
    
    params = {
        "n_estimators": [50, 100],
        "max_depth": [3, 5, None]
    }

    grid = GridSearchCV(rf, params, cv=3)
    grid.fit(X_train, y_train)

    best_model = grid.best_estimator_
    y_pred = best_model.predict(X_test)

    acc = accuracy_score(y_test, y_pred)
    pre = precision_score(y_test, y_pred)
    rec = recall_score(y_test, y_pred)
    f1 = f1_score(y_test, y_pred)

    results.append([segment, acc, pre, rec, f1])

results_df = pd.DataFrame(
    results,
    columns=["Segment", "Accuracy", "Precision", "Recall", "F1"]
)

print(results_df)
results_df.to_csv("model_evaluation_results.csv", index=False)

# -----------------------------
# STEP 7: Feature Importance
# -----------------------------
feature_importance = pd.Series(
    best_model.feature_importances_,
    index=X_seg.columns
)

feature_importance.sort_values().plot(kind="barh")
plt.title("Feature Importance")
plt.show()
